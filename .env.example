# Example environment variables for SonarQube
# Copy this file to `.env` (do NOT commit .env) and fill values.
SONARQUBE_TOKEN=your_sonar_token_here
SONARQUBE_URL=http://localhost:9000

# OTP Auth Backend
# The Express server lives in /server — see /server/.env.example for server-only vars.
VITE_API_BASE_URL=http://localhost:3001

# Supabase (Frontend)
VITE_SUPABASE_PROJECT_ID=mzgtfgtejmvozeifyrak
VITE_SUPABASE_URL=https://mzgtfgtejmvozeifyrak.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# OpenRouter (AI repository agent)
VITE_OPENROUTER_API_KEY=your_openrouter_api_key_here
# Default free model used by the repository agent.
VITE_OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
# Optional comma-separated fallbacks for temporary free-tier rate limits.
VITE_OPENROUTER_FALLBACK_MODELS=nvidia/nemotron-3-nano-30b-a3b:free,nvidia/nemotron-nano-9b-v2:free,google/gemma-4-26b-a4b-it:free
# Optional: set explicit app URL/title shown in OpenRouter analytics.
VITE_OPENROUTER_SITE_URL=http://localhost:8080
VITE_OPENROUTER_SITE_TITLE=Cyberspace-X Repository Agent

# Google Maps (Profile location picker – interactive map)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# LocationIQ (Geocoding – address search & reverse geocoding)
VITE_LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# GitHub OAuth Login
# Enabled in Supabase Dashboard -> Authentication -> Providers -> GitHub
# Requires setting up a GitHub OAuth App at https://github.com/settings/developers
# Callback URL: <your-supabase-url>/auth/v1/callback
# No separate VITE_ environment variables are needed as Supabase handles the OAuth flow.
