# Example environment variables for SonarQube
# Copy this file to `.env` (do NOT commit .env) and fill values.
SONARQUBE_TOKEN=your_sonar_token_here
SONARQUBE_URL=http://localhost:9000

# Supabase (Frontend)
VITE_SUPABASE_PROJECT_ID=mzgtfgtejmvozeifyrak
VITE_SUPABASE_URL=https://mzgtfgtejmvozeifyrak.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Google Maps (Profile location picker – interactive map)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# LocationIQ (Geocoding – address search & reverse geocoding)
VITE_LOCATIONIQ_API_KEY=your_locationiq_api_key_here

# GitHub OAuth Login
# Enabled in Supabase Dashboard -> Authentication -> Providers -> GitHub
# Requires setting up a GitHub OAuth App at https://github.com/settings/developers
# Callback URL: <your-supabase-url>/auth/v1/callback
# No separate VITE_ environment variables are needed as Supabase handles the OAuth flow.
